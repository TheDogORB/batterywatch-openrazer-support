<?xml version="1.0" encoding="UTF-8"?>
<kcfg xmlns="http://www.kde.org/standards/kcfg/1.0"
      xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:schemaLocation="http://www.kde.org/standards/kcfg/1.0
      http://www.kde.org/standards/kcfg/1.0/kcfg.xsd" >
  <kcfgfile name=""/>

  <group name="General">
    <entry name="hiddenDevices" type="String">
      <default></default>
    </entry>
    <entry name="debugMode" type="Bool">
      <default>false</default>
    </entry>
  </group>

  <!-- Appearance section -->
  <group name="Appearance">
    <entry name="fontFamily" type="String">
      <label>Widget font family</label>
      <default></default>
    </entry>

    <entry name="fontBold" type="Bool">
      <label>Shall font be bold?</label>
      <default>false</default>
    </entry>
    <entry name="fontWeight" type="Int">
      <label>Thickness of bold</label>
      <default>500</default>
    </entry>

    <entry name="fontItalic" type="Bool">
      <label>Shall font be italic?</label>
      <default>false</default>
    </entry>

    <entry name="useCustomFontSize" type="Bool">
      <default>false</default>
    </entry>
    <entry name="customFontSize" type="Int">
      <default>12</default>
    </entry>

    <entry name="useCustomIconSize" type="Bool">
      <default>false</default>
    </entry>
    <entry name="customIconSize" type="Int">
      <default>22</default>
    </entry>
    <!-- COLORS -->
    <entry name="useDefaultColor" type="Bool">
      <label>Enable custom battery colors</label>
      <default>false</default>
    </entry>
    <entry name="defaultCustomColor" type="Color">
      <label>Changes default color of battery</label>
      <default>#FFFFFF</default>
    </entry>

    <entry name="useChargingColor" type="Bool">
      <default>true</default>
    </entry>
    <entry name="chargingColor" type="Color">
      <default>#2196F3</default>
    </entry>

    <entry name="zoneOneColor" type="Color">
      <label>Changes color of battery when below threshold of zone one</label>
      <default>#DFC04C</default>
    </entry>
    <entry name="useZoneOneColor" type="Bool">
      <label>Toggle to allow use of zone one</label>
      <default>false</default>
    </entry>
    <entry name="zoneOneThreshold" type="Int">
      <label>Sets threshold for zone one, when below change color</label>
      <default>40</default>
    </entry>

    <entry name="useZoneTwoColor" type="Bool">
      <label>Toggle to allow use of zone two</label>
      <default>false</default>
    </entry>
    <entry name="zoneTwoColor" type="Color">
      <label>Changes color of battery when below threshold of zone two</label>
      <default>#EE665A</default>
    </entry>
    <entry name="zoneTwoThreshold" type="Int">
      <label>Sets threshold for zone two, when below change color</label>
      <default>20</default>
    </entry>
  </group>

  <!-- PROVIDERS -->
  <group name="OpenLinkHub">
    <entry name="enableOpenLinkHubIntegration" type="Bool">
      <default>true</default>
    </entry>
    <entry name="openLinkHubApiPort" type="Int">
      <default>27003</default>
    </entry>
  </group>

  <group name="OpenRazer">
    <entry name="useOpenRazerIntegration" type="Bool">
      <default>true</default>
    </entry>
    <entry name="openRazerPollingTime" type="Int">
      <default>5</default>
    </entry>
  </group>
</kcfg>
